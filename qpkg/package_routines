#!/bin/sh
# QPKG install/remove hooks

CONF=/etc/config/qpkg.conf
QPKG_NAME="mcp-server-qnap-qvs"

pkg_pre_install() {
    # Check if Docker is available (via Container Station)
    if [ ! -x /usr/local/bin/docker ]; then
        echo "ERROR: Docker is required. Please install Container Station first."
        return 1
    fi
}

pkg_post_install() {
    QPKG_DIR=$(getcfg $QPKG_NAME Install_Path -f $CONF)

    # Copy .env.example if .env doesn't exist
    if [ ! -f "${QPKG_DIR}/.env" ]; then
        cp "${QPKG_DIR}/.env.example" "${QPKG_DIR}/.env"
        echo "Created ${QPKG_DIR}/.env — please edit with your QNAP credentials."
    fi

    # Make service script executable
    chmod +x "${QPKG_DIR}/mcp-server-qnap-qvs.sh"

    # Pull the Docker image
    /usr/local/bin/docker pull ghcr.io/arnstarn/mcp-server-qnap-qvs:latest 2>/dev/null
}

pkg_pre_remove() {
    QPKG_DIR=$(getcfg $QPKG_NAME Install_Path -f $CONF)
    cd "${QPKG_DIR}" && /usr/local/bin/docker compose down 2>/dev/null
}
